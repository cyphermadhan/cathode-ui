{
  "$schema": "../scripts/tokens.schema.json",
  "version": "0.2.0",
  "color": {
    "dark": {
      "bg": "#000000",
      "panel": "#121212",
      "border": "#2E2E2E",
      "text": "#EAEAEA",
      "textDim": "#858585",
      "textFaint": "#383838",

      "danger": "#EB3D38",
      "dangerDeep": "#C22926",
      "warning": "#F29E33",
      "success": "#59D173",
      "info": "#38A8E2",
      "accent": "#EB73C7",

      "amber": "#F2C133",
      "pink": "#F266AD",
      "purple": "#B273F2",
      "teal": "#3AD6C7",
      "grey": "#9EA5B7"
    },
    "light": {
      "bg": "#F6F7F2",
      "panel": "#EEEEE7",
      "border": "#C5C8BF",
      "text": "#1B2030",
      "textDim": "#545B6B",
      "textFaint": "#B0B4A8",

      "danger": "#B42019",
      "dangerDeep": "#8A1410",
      "warning": "#9E5B13",
      "success": "#247235",
      "info": "#1E6FA8",
      "accent": "#A6327D",

      "amber": "#7F5F10",
      "pink": "#9C2868",
      "purple": "#5B31A6",
      "teal": "#0F6E62",
      "grey": "#4D5160"
    }
  },
  "type": {
    "scale": {
      "caption": 9,
      "readout": 11,
      "label": 13,
      "number": 16,
      "display": 24,
      "hero": 36
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "heavy": 800
    },
    "tracking": {
      "header": 2.0,
      "label": 1.4,
      "caption": 0.8
    },
    "fontStack": "'JetBrains Mono', 'SF Mono', 'Menlo', 'Consolas', monospace"
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "xxl": 32,
    "framePad": 12,
    "rowHeight": 28
  },
  "size": {
    "pixelCell": 6,
    "pixelSpacing": 2,
    "tileCorner": 2,
    "borderWidth": 1,
    "borderWidthActive": 1.5,
    "touchTargetMin": 44,
    "iconSm": 12,
    "iconMd": 16,
    "iconLg": 22
  },
  "motion": {
    "duration": {
      "instant": 80,
      "quick": 150,
      "settled": 300,
      "slow": 500
    },
    "ease": {
      "snap": "cubic-bezier(0.4, 0, 0.2, 1)",
      "gentle": "cubic-bezier(0.25, 0.1, 0.25, 1)",
      "overshoot": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "scale": {
      "press": 0.97,
      "pop": 1.03
    }
  },
  "sound": {
    "click": [
      { "freq": 1200, "ms": 30, "wave": "square", "gain": 0.05 }
    ],
    "tick": [
      { "freq": 1600, "ms": 15, "wave": "square", "gain": 0.03 }
    ],
    "confirm": [
      { "freq": 880, "ms": 60, "wave": "sine", "gain": 0.06 },
      { "freq": 1175, "ms": 80, "wave": "sine", "gain": 0.06, "delay": 50 }
    ],
    "warn": [
      { "freq": 600, "ms": 140, "wave": "triangle", "gain": 0.07 }
    ],
    "error": [
      { "freq": 440, "ms": 70,  "wave": "sawtooth", "gain": 0.08 },
      { "freq": 330, "ms": 120, "wave": "sawtooth", "gain": 0.08, "delay": 40 }
    ],
    "destructive": [
      { "freq": 180, "ms": 100, "wave": "sawtooth", "gain": 0.08 }
    ]
  },
  "haptic": {
    "tap": 10,
    "confirm": 20,
    "warn": [10, 30, 10],
    "error": [20, 40, 20],
    "destructive": 35,
    "long": 40
  },
  "breakpoint": {
    "sm": 480,
    "md": 768,
    "lg": 1024,
    "xl": 1280
  }
}
