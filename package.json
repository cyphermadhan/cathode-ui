{
  "name": "cathode-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Cathode UI — retro-future design system for mobile and web with motion, haptics, sound, and AI-native surfaces.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "gen:css": "node scripts/gen-css.js",
    "gen:swift": "node scripts/gen-swift.js",
    "gen:manifest": "node scripts/gen-manifest.js",
    "gen:ai-docs": "node scripts/gen-ai-docs.js",
    "gen": "npm run gen:css && npm run gen:swift && npm run gen:manifest && npm run gen:ai-docs",
    "build": "npm run build -w @cathode-ui/react",
    "dev": "npm run dev -w @cathode-ui/react",
    "storybook": "npm run storybook -w @cathode-ui/react",
    "test:a11y": "node scripts/a11y-test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "ajv": "^8.20.0"
  }
}
