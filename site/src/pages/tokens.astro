---
import Main from '../layouts/Main.astro';
import tokens from '../../../tokens/tokens.json';

/** Renders a single color swatch. */
function swatch(name: string, value: string) {
  return { name, value };
}

const darkSwatches = Object.entries(tokens.color.dark).map(([k, v]) => swatch(k, v as string));
const lightSwatches = Object.entries(tokens.color.light).map(([k, v]) => swatch(k, v as string));
const typeScale   = Object.entries(tokens.type.scale);
const spacing     = Object.entries(tokens.spacing);
const motionDur   = Object.entries(tokens.motion.duration);
const soundKeys   = Object.keys(tokens.sound);
const hapticKeys  = Object.entries(tokens.haptic);
---

<Main title="Tokens">
  <h1>TOKENS</h1>
  <div class="page-lead">
    Single source of truth: <code>tokens/tokens.json</code>. Everything below
    is rendered from that file — color palettes, type scale, spacing, motion
    timing, sound patterns, haptic durations.
  </div>

  <h2>Colors — Dark</h2>
  <div class="color-grid">
    {darkSwatches.map((s) => (
      <div class="color-swatch">
        <div class="color-swatch-chip" style={`background: ${s.value};`}></div>
        <div class="color-swatch-name">{s.name}</div>
        <div class="color-swatch-value">{s.value}</div>
      </div>
    ))}
  </div>

  <h2>Colors — Light</h2>
  <div class="color-grid">
    {lightSwatches.map((s) => (
      <div class="color-swatch">
        <div class="color-swatch-chip" style={`background: ${s.value};`}></div>
        <div class="color-swatch-name">{s.name}</div>
        <div class="color-swatch-value">{s.value}</div>
      </div>
    ))}
  </div>

  <h2>Type Scale</h2>
  <table>
    <thead>
      <tr><th>Name</th><th>Size</th><th>CSS var</th><th>Preview</th></tr>
    </thead>
    <tbody>
      {typeScale.map(([name, value]) => (
        <tr>
          <td>{name}</td>
          <td>{value}px</td>
          <td><code>--cathode-type-scale-{name}</code></td>
          <td style={`font-size: ${value}px; letter-spacing: 1.4px;`}>AaBb 01</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Spacing</h2>
  <table>
    <thead>
      <tr><th>Name</th><th>Size</th><th>CSS var</th></tr>
    </thead>
    <tbody>
      {spacing.map(([name, value]) => (
        <tr>
          <td>{name}</td>
          <td>{value}px</td>
          <td><code>--cathode-space-{name.replace(/[A-Z]/g, (c) => '-' + c.toLowerCase())}</code></td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Motion — Durations</h2>
  <table>
    <thead><tr><th>Name</th><th>ms</th></tr></thead>
    <tbody>
      {motionDur.map(([name, value]) => (
        <tr><td>{name}</td><td>{value} ms</td></tr>
      ))}
    </tbody>
  </table>

  <h2>Sound Palette</h2>
  <p>
    Every sound is synthesized via the Web Audio API — no audio files, no
    asset loads. Each pattern is a list of notes with frequency, duration,
    waveform, gain, and optional inter-note delay.
  </p>
  <table>
    <thead><tr><th>Name</th><th>Notes</th><th>Use</th></tr></thead>
    <tbody>
      <tr><td><code>click</code></td>       <td>1.2 kHz square, 30 ms</td>                   <td>button tap</td></tr>
      <tr><td><code>tick</code></td>        <td>1.6 kHz square, 15 ms, low gain</td>         <td>slider / stepper step</td></tr>
      <tr><td><code>confirm</code></td>     <td>880 → 1175 Hz sine, rising two-note</td>     <td>submit / success</td></tr>
      <tr><td><code>warn</code></td>        <td>600 Hz triangle, 140 ms</td>                 <td>heads-up</td></tr>
      <tr><td><code>error</code></td>       <td>440 → 330 Hz saw, descending two-note</td>   <td>system error ding-dong</td></tr>
      <tr><td><code>destructive</code></td> <td>180 Hz saw, 100 ms</td>                      <td>pre-action warning</td></tr>
    </tbody>
  </table>
  <p style="color: var(--cathode-color-text-dim); font-size: 11px;">
    {soundKeys.length} patterns defined in tokens.json.
  </p>

  <h2>Haptic Palette</h2>
  <table>
    <thead><tr><th>Name</th><th>Vibration pattern (ms)</th></tr></thead>
    <tbody>
      {hapticKeys.map(([name, value]) => (
        <tr>
          <td>{name}</td>
          <td>{Array.isArray(value) ? value.join(' · ') : value}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p style="color: var(--cathode-color-text-dim); font-size: 11px;">
    <code>navigator.vibrate</code> is unsupported on iOS Safari — Cathode UI
    gracefully no-ops there. For real iOS haptics use the (future) Swift package.
  </p>
</Main>
