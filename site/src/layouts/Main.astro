---
/**
 * Main site layout — sidebar + content grid. Imports Cathode's
 * tokens.css so every `var(--cathode-*)` reference on the docs
 * resolves, and dogfoods the design system end-to-end.
 */
import '@cathode-ui/react/tokens.css';
import '@cathode-ui/react/fonts.css';
import '@cathode-ui/react/styles.css';
import '../styles/site.css';
import { SiteControls } from '../components/SiteControls';
import manifest from '../../../cathode.manifest.json';
import { withBase, isActiveHref } from '../lib/href';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;

// Components listed in alphabetical order from the manifest — the
// authoritative list. Adding a new primitive to the manifest
// auto-populates the sidebar.
const componentItems = [...manifest.components]
  .sort((a: any, b: any) => a.name.localeCompare(b.name))
  .map((c: any) => ({
    href: `/components/${c.name.toLowerCase()}`,
    label: c.name,
  }));

const nav = [
  {
    label: 'Intro',
    items: [
      { href: '/',                label: 'Home' },
      { href: '/getting-started', label: 'Getting Started' },
      { href: '/tokens',          label: 'Tokens' },
    ],
  },
  {
    label: 'Components',
    items: [
      { href: '/components', label: 'All components' },
      ...componentItems,
    ],
  },
  {
    label: 'AI',
    items: [
      { href: '/ai',  label: 'AI providers' },
      { href: '/mcp', label: 'MCP server' },
    ],
  },
  {
    label: 'Design',
    items: [
      { href: '/figma',    label: 'Figma library' },
      { href: '/patterns', label: 'Patterns' },
    ],
  },
];

function isActive(href: string): boolean {
  return isActiveHref(href, path);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Cathode UI</title>
    {description ? <meta name="description" content={description} /> : null}
    {/* Avoid a theme flash: pin data-theme before first paint from
        whatever the user last chose. Runs inline before <body>. */}
    <script is:inline>
      try {
        const raw = localStorage.getItem('cathode-site-settings');
        const theme = raw ? JSON.parse(raw).theme : 'auto';
        if (theme === 'dark' || theme === 'light') {
          document.documentElement.setAttribute('data-theme', theme);
        }
      } catch (e) { /* ignore — fall back to auto */ }
    </script>
    {/* Persist the sidebar scroll position across in-site
        navigations so clicking a component in the long sidebar
        doesn't reset the list to the top each time. */}
    <script is:inline>
      (function () {
        const KEY = 'cathode-site-sidebar-scroll';
        function restore() {
          try {
            const el = document.querySelector('.site-sidebar');
            if (!el) return;
            const stored = sessionStorage.getItem(KEY);
            if (stored) el.scrollTop = parseInt(stored, 10);
            el.addEventListener('scroll', function () {
              sessionStorage.setItem(KEY, String(el.scrollTop));
            }, { passive: true });
          } catch (e) { /* ignore */ }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', restore);
        } else {
          restore();
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <aside class="site-sidebar">
        <div class="site-brand">CATHODE · UI</div>
        <div class="site-tagline">Retro-future design system</div>
        <nav class="site-nav" aria-label="Documentation">
          {nav.map((group) => (
            <>
              <div class="site-nav-group-label">{group.label}</div>
              {group.items.map((item) => (
                <a href={withBase(item.href)} class={isActive(item.href) ? 'is-active' : ''}>
                  {item.label}
                </a>
              ))}
            </>
          ))}
        </nav>
      </aside>

      <main class="site-main">
        <SiteControls client:load />
        <slot />
      </main>
    </div>
  </body>
</html>
